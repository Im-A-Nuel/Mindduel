# ── Frontend (Next.js) env ─────────────────────────────────────────────
# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to the browser.

# Deployed MindDuelRanking contract on Celo mainnet (from the Foundry deploy).
NEXT_PUBLIC_RANKING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Celo RPC the frontend reads points/leaderboard from.
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Backend (Fastify) base URL. In production this MUST be the deployed backend,
# e.g. https://mindduel-production-celo.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# WebSocket URL. OPTIONAL - derived from NEXT_PUBLIC_BACKEND_URL when unset
# (https -> wss, http -> ws), since the API and /ws rooms share a host.
# Only set this if the WebSocket lives somewhere else. Never point it at
# localhost from a deployed build, and never use ws:// on an https page:
# browsers block that as mixed content.
# NEXT_PUBLIC_WS_URL=wss://your-backend.example.com
