# Deployer / relayer private key (0x-prefixed). Funds the Celo mainnet deploy
# and submits match results. NEVER commit the real value.
PRIVATE_KEY=

# Optional RPC overrides (defaults: Celo Forno public endpoints).
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Contract owner = the backend relayer address. Defaults to the deployer.
RELAYER_ADDRESS=

# For `npm run verify` on Celoscan.
CELOSCAN_API_KEY=
