# ── Backend (Fastify) env ──────────────────────────────────────────────
# Copy to .env and fill in.

# Postgres (e.g. Neon). Required.
DATABASE_URL=postgres://user:pass@host/db

# ── Celo on-chain ranking relayer ──────────────────────────────────────
# Deployed MindDuelRanking contract. If unset, the backend runs DB-only
# (ranked results are NOT recorded on-chain).
RANKING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Private key of the contract OWNER. The backend submits recordMatch() from
# this account and pays the CELO gas. NEVER commit the real value.
RELAYER_PRIVATE_KEY=0x...

# Celo RPC. Defaults to Forno mainnet.
CELO_RPC_URL=https://forno.celo.org

# ── Server ─────────────────────────────────────────────────────────────
PORT=3001
# Comma-separated allowed CORS origins (your frontend URL).
ALLOWED_ORIGINS=http://localhost:3000
# Set to 1 to allow *.vercel.app preview origins.
ALLOW_VERCEL_PREVIEW=0
