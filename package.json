{
  "name": "mindduel-celo",
  "version": "0.1.0",
  "private": true,
  "description": "MindDuel on Celo — trivia + tic-tac-toe duel with on-chain points & ranking (Proof of Ship)",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "frontend": "npm run dev --workspace=frontend",
    "backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "typecheck": "npm run typecheck --workspace=frontend && npm run typecheck --workspace=backend",
    "contracts:build": "wsl -d Ubuntu-Ext -- bash -lc 'cd /mnt/f/Hack/celo/mindduel/contracts && forge build'",
    "contracts:test": "wsl -d Ubuntu-Ext -- bash -lc 'cd /mnt/f/Hack/celo/mindduel/contracts && forge test -vvv'"
  }
}
